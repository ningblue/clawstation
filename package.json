{
  "name": "xclaw",
  "version": "0.1.1",
  "description": "AI数字员工桌面应用，基于OpenClaw引擎",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build": "npm run build:openclaw && npm run archive:openclaw && npm run download:node && npm run build:main && npm run build:renderer && electron-builder",
    "build:openclaw": "node scripts/build-openclaw.js",
    "archive:openclaw": "node scripts/archive-openclaw.js",
    "download:node": "node scripts/download-node.js",
    "build:main": "tsc",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "ai",
    "digital-worker",
    "openclaw",
    "electron"
  ],
  "author": "XClaw Team",
  "license": "MIT",
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "@electron/fuses": "^2.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "archiver": "^7.0.1",
    "electron": "^40.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.3.2",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.19"
  }
}

{
  "name": "clawstation",
  "version": "0.1.0",
  "description": "AI数字员工桌面应用，基于OpenClaw引擎",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build": "npm run build:openclaw && npm run build:main && npm run build:renderer && electron-builder",
    "build:openclaw": "node scripts/build-openclaw.js",
    "build:main": "tsc",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "ai",
    "digital-worker",
    "openclaw",
    "electron"
  ],
  "author": "ClawStation Team",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.3.0"
  }
}
{
  "name": "xclaw",
  "version": "0.2.0",
  "description": "AI数字员工桌面应用，基于OpenClaw引擎",
  "main": "dist/main/index.js",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "esbuild", "msw"]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "jest --runInBand",
    "setup:dev": "node scripts/setup.js",
    "setup:dev:full": "npm run build:openclaw && npm run setup:dev",
    "clean": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "npm run setup:dev && npm run build:main && npm run build:renderer && electron-builder",
    "build:openclaw": "node scripts/build-openclaw.js",
    "archive:openclaw": "node scripts/archive-openclaw.js",
    "download:node": "node scripts/download-node.js",
    "build:main": "tsc",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "ai",
    "digital-worker",
    "openclaw",
    "electron"
  ],
  "author": "XClaw Team",
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^2.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "7zip-bin": "^5.2.0",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.0.0",
    "postcss": "^8.5.8",
    "jest": "^29.7.0",
    "react-syntax-highlighter": "^16.1.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0"
  }
}
